# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB Atlas Connection String
# Lấy từ: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/estore?retryWrites=true&w=majority

# JWT Secret (chuỗi bất kỳ, dài >32 ký tự)
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long

# JWT Expiration
JWT_EXPIRE=7d

# Email SMTP Config (Gmail App Password)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password_16_chars

# Frontend URL (Vercel domain sau khi deploy)
CLIENT_URL=https://your-app-name.vercel.app
